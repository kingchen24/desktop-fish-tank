{
  "name": "desktop-fish-tank",
  "version": "1.0.0",
  "description": "🐟 桌面小鱼缸 - 轻量挂机养鱼游戏",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.fishtank.desktop",
    "productName": "桌面小鱼缸",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": ["portable"],
      "icon": null
    },
    "files": [
      "index.html",
      "style.css",
      "app.js",
      "main.js",
      "preload.js"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "author": "",
  "license": "MIT"
}
